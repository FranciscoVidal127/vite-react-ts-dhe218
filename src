        .from('posts')
        .select('*')
        .order('created_at', { ascending: false });

      if (!error && data) {
        const dbPosts: Escrito[] = data.map((post) => ({
          id: post.id,
          title: post.title,
          category: post.category || 'Escrita',
          date: post.date || '',
          readTime: post.read_time || '',
          excerpt: post.excerpt || '',
          slug: post.slug,
          tags: post.tags || [],
